NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

FAREHARBOR_API_APP=
FAREHARBOR_API_USER=
FAREHARBOR_API_BASE=https://fareharbor.com/api/v1

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Google OAuth client — reused by Google Ads conversion tracking (lib/google-ads/auth.ts)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Outscraper — reviews scraping (Google Maps + TripAdvisor) for the admin Reviews page.
# Get the key from app.outscraper.cloud → Profile. The same key is used to verify
# incoming webhook signatures (HMAC-SHA256). Configure place_id + TripAdvisor URL in the admin panel.
OUTSCRAPER_API_KEY=

NEXT_PUBLIC_SITE_URL=https://offcourseamsterdam.com
REVALIDATION_SECRET=
# Bearer secret Vercel sends to every cron route (/api/cron/**, /api/fareharbor/sync).
# Vercel injects it automatically when set in the project env.
CRON_SECRET=
EXTRAS_TOKEN_SECRET=

# Local development ONLY — set to 'true' in .env.local to skip admin login.
# Never set this in any deployed environment (it is also gated on NODE_ENV=development).
ADMIN_DEV_BYPASS=

# Slack incoming webhook — for booking notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Resend — for confirmation emails to guests
# Create at: https://resend.com → API Keys
RESEND_API_KEY=

# Catering order email recipient
# Test: info@offcourseamsterdam.com — Production: cruise@pureboats.com
CATERING_EMAIL_RECIPIENT=

# Supabase Management API token — for running migrations + type regen via the
# Management API (see CLAUDE.md → "Running migrations"). Server/CLI use only.
# Create at: supabase.com → Account (top right) → Access Tokens → Generate new token
SUPABASE_MANAGEMENT_TOKEN=

# Google Ads — server-side conversion tracking (Offline Conversion Import).
# When a Stripe payment succeeds, the webhook reports the conversion to Google
# using the gclid captured on the ad click. See docs/features/google-ads-conversion-tracking.md.
# 1. Apply for a developer token: Google Ads → Tools → API Center → Basic access
# 2. Create an "Import" conversion action (category Purchase) → copy its numeric ID
# 3. Reuse GOOGLE_OAUTH_CLIENT_ID/SECRET above (enable Google Ads API in the same
#    Cloud project) OR set Ads-specific ones below; generate a refresh token with
#    the https://www.googleapis.com/auth/adwords scope.
# Google Ads tag — Consent Mode v2 + remarketing audiences (no GTM, no Analytics needed)
# Format: AW-XXXXXXXXXX — find it in Google Ads → Admin → Google tag → Tag ID
NEXT_PUBLIC_GOOGLE_ADS_TAG_ID=

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=          # 10-digit account, no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # only if under a manager (MCC); else leave blank
GOOGLE_ADS_CONVERSION_ACTION_ID= # numeric ID of the Import conversion action
GOOGLE_ADS_REQUIRE_CONSENT=true  # gate send-to-Google on cookie consent (default true)
GOOGLE_ADS_API_VERSION=          # e.g. v18 — set to the CURRENT version (API Center); versions sunset ~yearly
