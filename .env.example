# Google Reviews integration (admin panel → Reviews page)
# 1. Create OAuth client: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
#    Add redirect URI: https://offcourse-fresh.vercel.app/api/admin/reviews/google-auth/callback
# 2. Enable APIs: Google Places API (New), Google My Business API
# 3. Create API key for Places API (restrict to Places API only)
# 4. Find Place ID: Google Maps → search "Off Course Amsterdam" → Share → copy Place ID
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

NEXT_PUBLIC_SITE_URL=https://offcourseamsterdam.com
REVALIDATION_SECRET=

# Slack incoming webhook — for booking notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Resend — for confirmation emails to guests
# Create at: https://resend.com → API Keys
RESEND_API_KEY=

# Supabase Management API token — for running migrations via /api/admin/migrate
# Create at: supabase.com → Account (top right) → Access Tokens → Generate new token
SUPABASE_MANAGEMENT_TOKEN=
